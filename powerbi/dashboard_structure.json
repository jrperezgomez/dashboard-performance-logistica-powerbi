            "backgroundColor": "#F0F6FE",
            "titleColor": "#0078D4",
            "valueColor": "#0078D4",
            "tooltipOn": true
          },
          {
            "id": "card_produtividade",
            "type": "Card",
            "position": { "x": 250, "y": 0, "width": 250, "height": 140 },
            "measure": "Produtividade Média",
            "title": "Produtividade",
            "icon": "⚡",
            "format": "0.00",
            "backgroundColor": "#F0FEF6",
            "titleColor": "#107C10",
            "valueColor": "#107C10",
            "tooltipOn": true
