          },
          {
            "id": "table_kpi_summary",
            "type": "Table",
            "position": { "x": 0, "y": 460, "width": 1000, "height": 180 },
            "title": "Resumo KPIs",
            "columns": [
              {
                "field": "dim_turno[Nome]",
