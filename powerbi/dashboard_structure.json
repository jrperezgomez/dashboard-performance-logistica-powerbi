{
  "dashboard": {
    "metadata": {
      "name": "Dashboard Operacional Logístico",
      "version": "1.0",
      "author": "José Pérez",
      "date": "2026-07-07",
      "description": "Dashboard interativo para análise de operações logísticas",
      "currency": "BRL",
      "language": "pt-BR"
    },
    "dataModel": {
      "tables": [
        {
          "name": "fato_operacoes",
          "type": "Fact",
          "granularity": "One row per operation",
          "source": "CSV",
          "columns": [
            {
              "name": "data",
              "type": "Date",
              "format": "dd/mm/yyyy",
              "nullable": false
            },
            {
              "name": "operador",
              "type": "Text",
              "example": "OP001",
              "nullable": false
            },
            {
              "name": "turno",
              "type": "Text",
              "values": ["Matutino", "Vespertino", "Noturno"],
              "nullable": false
            },
            {
              "name": "produto",
              "type": "Text",
              "example": "Notebook",
              "nullable": false
            },
            {
              "name": "categoria",
              "type": "Text",
              "values": ["Eletrônicos", "Vestuário", "Alimentos", "Limpeza", "Higiene", "Mobiliário", "Papelaria"],
              "nullable": false
            },
            {
              "name": "volume",
              "type": "Integer",
              "range": "10-500",
              "aggregate": "Sum",
              "nullable": false
            },
            {
              "name": "tempo_processamento_minutos",
              "type": "Integer",
              "range": "5-180",
              "aggregate": "Sum",
              "nullable": false
            },
            {
              "name": "status",
              "type": "Text",
              "values": ["Completado", "Com_Erro", "Incompleto"],
              "nullable": false
            },
            {
              "name": "divergencia",
              "type": "Integer",
              "values": [0, 1],
              "nullable": false
            },
            {
              "name": "acuracia_percentual",
              "type": "Integer",
              "range": "0-100",
              "aggregate": "Average",
              "nullable": false
            },
            {
              "name": "sla_cumprido",
              "type": "Integer",
              "values": [0, 1],
              "nullable": false
            }
          ]
        },
        {
          "name": "dim_data",
          "type": "Dimension",
          "source": "Generated from fato_operacoes[data]",
          "columns": [
            {
              "name": "Data",
              "type": "Date",
              "format": "dd/mm/yyyy"
            },
            {
              "name": "Ano",
              "type": "Integer",
              "formula": "YEAR([Data])"
            },
            {
              "name": "Mês",
              "type": "Integer",
              "formula": "MONTH([Data])"
            },
            {
              "name": "Nome Mês",
              "type": "Text",
              "formula": "FORMAT([Data], \"MMMM\")"
            },
            {
              "name": "Dia",
              "type": "Integer",
              "formula": "DAY([Data])"
            },
            {
              "name": "Dia Semana",
              "type": "Text",
              "formula": "FORMAT([Data], \"DDDD\")"
            },
            {
              "name": "Semana",
              "type": "Integer",
              "formula": "WEEKNUM([Data])"
            },
            {
              "name": "Trimestre",
              "type": "Integer",
              "formula": "ROUNDUP(MONTH([Data])/3, 0)"
            }
          ]
        },
        {
          "name": "dim_operador",
          "type": "Dimension",
          "source": "DISTINCT(fato_operacoes[operador])",
          "columns": [
            {
              "name": "Código",
              "type": "Text"
            },
            {
              "name": "Experiência (meses)",
              "type": "Integer",
              "range": "5-48"
            },
            {
              "name": "Treinado",
              "type": "Boolean"
            }
          ]
        },
        {
          "name": "dim_turno",
          "type": "Dimension",
          "rows": 3,
          "columns": [
            {
              "name": "Nome",
              "type": "Text",
              "values": ["Matutino", "Vespertino", "Noturno"]
            },
            {
              "name": "Hora Inicio",
              "type": "Time",
              "values": ["06:00", "14:00", "22:00"]
            },
            {
              "name": "Hora Fim",
              "type": "Time",
              "values": ["14:00", "22:00", "06:00"]
            }
          ]
        },
        {
          "name": "dim_produto",
          "type": "Dimension",
          "source": "DISTINCT(fato_operacoes[categoria], fato_operacoes[produto])",
          "columns": [
            {
              "name": "Categoria",
              "type": "Text"
            },
            {
              "name": "Produto",
              "type": "Text"
            }
          ]
        }
      ],
      "relationships": [
        {
          "from": "dim_data[Data]",
          "to": "fato_operacoes[data]",
          "cardinality": "1:N",
          "direction": "Both",
          "active": true
        },
        {
          "from": "dim_operador[Código]",
          "to": "fato_operacoes[operador]",
          "cardinality": "1:N",
          "direction": "Both",
          "active": true
        },
        {
          "from": "dim_turno[Nome]",
          "to": "fato_operacoes[turno]",
          "cardinality": "1:N",
          "direction": "Both",
          "active": true
        },
        {
          "from": "dim_produto[Categoria]",
          "to": "fato_operacoes[categoria]",
          "cardinality": "1:N",
          "direction": "Both",
          "active": true
        }
      ]
    },
    "measures": [
      {
        "name": "Total Volume",
        "dax": "SUM(fato_operacoes[volume])",
        "format": "0",
        "unit": "itens",
        "category": "Volume",
        "tooltip": "Total de unidades processadas no período"
      },
      {
        "name": "Produtividade Média",
        "dax": "SUM(fato_operacoes[volume]) / SUM(fato_operacoes[tempo_processamento_minutos])",
        "format": "0.00",
        "unit": "itens/min",
        "category": "Produtividade",
        "tooltip": "Eficiência: unidades por minuto"
      },
      {
        "name": "Tempo Médio Processamento",
        "dax": "AVERAGE(fato_operacoes[tempo_processamento_minutos])",
        "format": "0",
        "unit": "minutos",
        "category": "Tempo",
        "tooltip": "Ciclo médio de operação"
      },
      {
        "name": "Acurácia Média",
        "dax": "AVERAGE(fato_operacoes[acuracia_percentual])",
        "format": "0.00%",
        "unit": "%",
        "category": "Qualidade",
        "tooltip": "Taxa de precisão em operações"
      },
      {
        "name": "Taxa Divergência",
        "dax": "VAR Divergencias = COUNTIF(fato_operacoes[divergencia], 1) VAR Total = COUNTA(fato_operacoes[divergencia]) RETURN IF(Total = 0, 0, DIVIDE(Divergencias, Total, 0) * 100)",
        "format": "0.00%",
        "unit": "%",
        "category": "Qualidade",
        "tooltip": "Percentual de erros identificados"
      },
      {
        "name": "Cumprimento SLA",
        "dax": "VAR Cumprido = COUNTIF(fato_operacoes[sla_cumprido], 1) VAR Total = COUNTA(fato_operacoes[sla_cumprido]) RETURN IF(Total = 0, 0, DIVIDE(Cumprido, Total, 0) * 100)",
        "format": "0.00%",
        "unit": "%",
        "category": "SLA",
        "tooltip": "Operações dentro do prazo"
      },
      {
        "name": "Total Operações",
        "dax": "COUNTA(fato_operacoes[data])",
        "format": "0",
        "unit": "ops",
        "category": "Volume",
        "tooltip": "Número total de operações"
      },
      {
        "name": "Operações Com Erro",
        "dax": "COUNTIF(fato_operacoes[status], \"Com_Erro\")",
        "format": "0",
        "unit": "ops",
        "category": "Qualidade",
        "tooltip": "Operações com problemas"
      }
    ],
    "pages": [
