                "alignment": "Right"
              },
              {
                "field": "Taxa Divergência",
                "header": "Divergência %",
                "format": "0.00%",
                "width": 130,
                "alignment": "Right"
              }
            ],
            "alternatingRowColor": true,
            "frozenHeader": true
          }
        ],
        "slicers": [
          {
            "id": "slicer_data",
